# Your team's dedicated Sinas instance.
# Runtime API base (agent invocation, files). Often the same host as management.
SINAS_URL=https://your-team.sinas.example.com

# Management API base for config apply. Defaults to SINAS_URL if unset.
SINAS_MGMT_URL=

# API key / bearer token from the Sinas console (Settings → API Keys).
SINAS_TOKEN=sk-sinas-xxxxxxxxxxxxxxxxxxxx

# Namespace everything is deployed under.
AIACT_NAMESPACE=aiact

# LLM provider id configured in your Sinas instance (leave blank for system default).
# Anthropic is recommended for this use case (long-context legal reasoning).
LLM_PROVIDER_ID=
LLM_MODEL=claude-opus-4-8
